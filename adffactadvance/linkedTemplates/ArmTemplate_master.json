{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adffactadvance"
		},
		"ls_datalake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_datalake'"
		},
		"ls_sqlexpress_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sqlexpress'"
		},
		"ls_datalake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://storageadvjack.dfs.core.windows.net/"
		},
		"ls_restapi_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://pokeapi.co/api/v2/pokemon"
		},
		"ls_sqlexpress_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "DESKTOP-0KPSU0R\\SQLEXPRESS"
		},
		"ls_sqlexpress_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "dbo"
		},
		"ls_sqlexpress_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "desktop-0kpsu0r\\lenovo"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adffactadvance_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_datalake_accountKey": {
						"value": "[parameters('ls_datalake_accountKey')]"
					},
					"ls_sqlexpress_password": {
						"value": "[parameters('ls_sqlexpress_password')]"
					},
					"ls_datalake_properties_typeProperties_url": {
						"value": "[parameters('ls_datalake_properties_typeProperties_url')]"
					},
					"ls_restapi_properties_typeProperties_url": {
						"value": "[parameters('ls_restapi_properties_typeProperties_url')]"
					},
					"ls_sqlexpress_properties_typeProperties_server": {
						"value": "[parameters('ls_sqlexpress_properties_typeProperties_server')]"
					},
					"ls_sqlexpress_properties_typeProperties_database": {
						"value": "[parameters('ls_sqlexpress_properties_typeProperties_database')]"
					},
					"ls_sqlexpress_properties_typeProperties_userName": {
						"value": "[parameters('ls_sqlexpress_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}